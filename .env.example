# thoughtstream — required credentials
# Copy this to .env and fill in your values

# Groq API key — free tier handles plenty of transcriptions
# Get one at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Slack Bot Token — needs chat:write and files:write scopes
# Create a bot at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack channel ID (right-click channel in Slack → Copy link, ID is at the end)
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Optional — where to store local transcript copies + logs
# Defaults to ~/thoughtstream-data if not set
# THOUGHTSTREAM_DATA_DIR=/path/to/your/data/dir

# Optional — path to claude CLI if not at ~/.local/bin/claude
# Used for AI summarization. If missing, falls back to raw transcript.
# CLAUDE_BIN=/path/to/claude
